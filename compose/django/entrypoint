#!/bin/bash

# if any of the commands in your code fails for any reason, the entire script fails
set -o errexit
# fail exit if one of your pipe command fails
set -o pipefail
# exits if any of your variables is not set
set -o nounset

# Auto-copy .env.example if .env is missing
if [ ! -f .env ] && [ -f .env.example ]; then
  cp .env.example .env
fi

# Check for PostgreSQL readiness without using Python to avoid early ssl import
export PGPASSWORD="${POSTGRES_PASSWORD}"

until pg_isready -h "${POSTGRES_HOST}" -p "${POSTGRES_PORT:-5432}" -U "${POSTGRES_USER}" -d "${POSTGRES_DB}" -q; do
  >&2 echo 'Waiting for PostgreSQL to become available...'
  sleep 1
done

# Unset the password variable after use for security
unset PGPASSWORD
>&2 echo 'PostgreSQL is available'

exec "$@"
